# Scraper environment variables
ENV=development
LOG_LEVEL=INFO

# Backend API - update with your Railway URL for production
API_URL=http://localhost:3001
API_EMAIL=scraper@mosque-platform.com
API_PASSWORD=scraper_password_123

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000

# Playwright
BROWSER_HEADLESS=true
REQUEST_DELAY_MS=2000
PAGE_TIMEOUT_MS=30000

# Scraping limits
MAX_RETRIES=3
CONFIDENCE_THRESHOLD=0.7
MAX_MOSQUES_PER_RUN=50

# Optional proxy for avoiding rate limits
# PROXY_URL=http://user:pass@proxy.example.com:8080
